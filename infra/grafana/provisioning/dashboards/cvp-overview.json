{
  "uid": "cvp-overview",
  "title": "Synapse — Backend Overview",
  "tags": ["cv-platform"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP requests / sec (by URI)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"cv-platform-backend\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p95 latency (s) by URI",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"cv-platform-backend\"}[5m])))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "JVM heap used (MB)",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"cv-platform-backend\",area=\"heap\"}) / 1024 / 1024"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Live threads",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"cv-platform-backend\"}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP error rate (%)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "100 * (sum(rate(http_server_requests_seconds_count{application=\"cv-platform-backend\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"cv-platform-backend\"}[1m])))",
          "legendFormat": "5xx %"
        }
      ]
    }
  ]
}
