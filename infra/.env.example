# Copy to .env and edit. Used by docker-compose and services in dev.

# Postgres
POSTGRES_USER=cvp
POSTGRES_PASSWORD=cvp_dev_pass
POSTGRES_DB=cvplatform
POSTGRES_PORT=5432

# Mongo
MONGO_USER=cvp
MONGO_PASSWORD=cvp_dev_pass
MONGO_DB=cvplatform
MONGO_PORT=27017

# RabbitMQ
RABBITMQ_USER=cvp
RABBITMQ_PASSWORD=cvp_dev_pass

# Redis
REDIS_PASSWORD=cvp_dev_pass

# MinIO
MINIO_ROOT_USER=cvp
MINIO_ROOT_PASSWORD=cvp_dev_pass

# Backend (Spring Boot)
JWT_SECRET=change-me-to-a-long-random-string-in-prod
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# AI Service
GEMINI_API_KEY=your-gemini-api-key-here
GITHUB_TOKEN=optional-github-personal-access-token

# Iyzico (sandbox)
IYZICO_API_KEY=sandbox-key
IYZICO_SECRET_KEY=sandbox-secret
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
