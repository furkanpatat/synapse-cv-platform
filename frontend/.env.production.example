# Copy to .env.production and fill, OR pass as build args / runtime env.
# NEXT_PUBLIC_* values are baked into the bundle at `next build` time —
# so they must be present when the image is built, NOT just at runtime.

# Backend public URL (where the browser will reach the API)
NEXT_PUBLIC_API_BASE_URL=https://api.synapse.example.com/api

# WebSocket URL (mesajlaşma + bildirimler + WebRTC sinyalleşme)
NEXT_PUBLIC_WS_URL=https://api.synapse.example.com/api/ws
